generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  OWNER
  ADMIN
  STAFF
  CLIENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// Новые статусы для подписок
enum Plan {
  FREE
  STARTER
  PRO
  PREMIUM
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  isSuspended Boolean  @default(false)

  primaryColor String? @default("#0071E3")
  logoUrl      String?
  city         String? @default("Алматы")
  timezone     String  @default("Asia/Almaty")

  users        User[]
  services     Service[]
  staff        Staff[]
  bookings     Booking[]
  schedules    Schedule[]
  clients      Client[]
  serviceCategories ServiceCategory[]
  subscription Subscription?
  paymentRequests PaymentRequest[]
  reviews      Review[]
  chatMessages ChatMessage[]
  complaints   Complaint[]
  telegramChatId String?
}


// Модель Подписки салона (Монетизация SaaS)
model Subscription {
  id              String   @id @default(cuid())
  plan            Plan     @default(FREE)
  validUntil      DateTime
  isActive        Boolean  @default(true)
  
  kaspiPaymentId  String?  @unique
  paymentStatus   PaymentStatus @default(PENDING)
  
  customDiscount  Int      @default(0) // Индивидуальная скидка для этого салона
  
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentRequest {
  id        String   @id @default(cuid())
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  plan      Plan
  amount    Int
  status    PaymentStatus @default(PENDING)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phoneNumber String?  @unique
  password    String?
  name        String
  role        Role     @default(CLIENT)
  
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  
  bookings    Booking[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// CRM: Карточка клиента
model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  bookings  Booking[] // Привязка к истории записей
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  services  Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int
  price       Float
  imageUrl    String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  categoryId  String?
  category    ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  bookings    Booking[]
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  bookings  Booking[]
  schedules Schedule[]
  
  commissionPercentage Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  telegramChatId String?
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      @default(5)
  comment     String?
  clientName  String
  
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  
  staffId   String?
  tenantId  String
  
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime 
  status      BookingStatus @default(PENDING)
  
  clientName  String
  clientPhone String
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  clientEmail String?
  
  // Привязка к CRM сущности клиента
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  
  tenantId    String
  serviceId   String
  staffId     String
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id])
  staff       Staff    @relation(fields: [staffId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model ChatMessage {
  id          String   @id @default(cuid())
  content     String
  
  senderId    String
  receiverId  String?  // Can be null for broadcasts
  
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  
  senderType  String   // "CLIENT", "OWNER", "SUPERADMIN"
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

model SystemMessage {
  id        String   @id @default(cuid())
  title     String?  @default("Уведомление от платформы")
  content   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS
  isActive  Boolean  @default(true)
  
  targetTenantId String? // Если null, то всем. Иначе - конкретному ID
  
  createdAt DateTime @default(now())
}

model PromoCode {
  id                 String   @id @default(cuid())
  code               String   @unique
  discountPercentage Int
  maxUses           Int      @default(100)
  usedCount         Int      @default(0)
  expirationDate    DateTime
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenantName String?
  action    String   // e.g., "NEW_BOOKING", "NEW_CLIENT", "PLAN_CHANGE"
  details   String?
  createdAt DateTime @default(now())
}

model GlobalSettings {
  id                 String   @id @default("global")
  platformCommission Float    @default(5)
  
  // Цены тарифов
  starterPrice       Int      @default(15000)
  proPrice           Int      @default(25000)
  premiumPrice       Int      @default(45000)
  
  // Общая скидка на платформе
  globalDiscount     Int      @default(0)

  updatedAt          DateTime @updatedAt
}

model Complaint {
  id        String   @id @default(cuid())
  subject   String
  content   String
  status    ComplaintStatus @default(PENDING)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

